PORT=3000

MONGODB_URI=mongodb://localhost:27017/virtualcare_ng

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Paystack (Nigerian payment gateway — replaces Stripe)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Daily.co for video calls
DAILY_API_KEY=your_daily_co_key

# OpenAI for Virtualcare AI
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# File storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Nigerian support address)
SENDGRID_API_KEY=
FROM_EMAIL=support@virtualcare.ng
FROM_NAME=Virtualcare Nigeria

# App
CLIENT_URL=http://localhost:3000
APP_NAME=Virtualcare Nigeria
COUNTRY=Nigeria
CURRENCY=NGN
CURRENCY_SYMBOL=₦
TIMEZONE=Africa/Lagos
PLATFORM_FEE_PERCENT=30

USE_MEMORY_DB=false
