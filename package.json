{
  "name": "virtualcare",
  "version": "1.0.0",
  "description": "Virtualcare Nigeria — MDCN-compliant telemedicine PWA",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:debug": "nodemon --inspect server/index.js",
    "seed": "node server/config/seed.js",
    "test": "node --test server/tests/basic.test.js",
    "lint": "echo \"Add ESLint config to run lint\"",
    "health": "node -e \"fetch('http://localhost:3000/api/health').then(r=>r.json()).then(console.log)\""
  },
  "keywords": [
    "telemedicine",
    "pwa",
    "healthcare"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
